# 배포에 불필요한 대용량/원본 제외 (사이트는 data/*.geojson·*.json 만 fetch)
node_modules
.git
scripts
tests
synthetic
*.py
_*.js
_*.tsv
# KOSIS 원본 CSV (0.9GB) — 런타임 미사용(통계는 *_stats.json 에 사전계산)
data/*.csv
data/*.next.*
data/_kosis_manifest.tsv
data/synthetic_baseline.json
data/population.json
# 월별 원천(pop_YYYYMM.json)만 제외하고 런타임 pop_pyramid.json은 포함
data/pop_[0-9]*.json
data/DT_*.json
data/*.xls
data/*.xlsx

# 시크릿 — 루트에서 vercel CLI 직접 배포 시에도 절대 번들 금지(심층방어)
.env
config.local.js
scripts/ors_key.txt
